{
  "name": "vibecurve-ad",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion video ad for VibeCurve — a standalone workspace, isolated from the Next.js app.",
  "scripts": {
    "start": "remotion studio src/index.ts",
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts VibeCurveAd out/vibecurve-ad.mp4",
    "render:vertical": "remotion render src/index.ts VibeCurveAdVertical out/vibecurve-ad-vertical.mp4",
    "still": "remotion still src/index.ts Poster out/poster.png --frame=50",
    "typecheck": "tsc --noEmit",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "4.0.484",
    "@remotion/google-fonts": "4.0.484",
    "@remotion/transitions": "4.0.484",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.484"
  },
  "devDependencies": {
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "typescript": "5.7.3"
  }
}
